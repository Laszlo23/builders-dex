# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional model override (default: gemini-3-flash-preview)
# GEMINI_MODEL="gemini-3-flash-preview"

# JUPITER_API_KEY: Required for production-rate Jupiter Swap / Tokens API.
# Create a key at https://portal.jup.ag — keep this server-side only.
# Keyless access works at very low rate limits for local prototypes.
JUPITER_API_KEY="MY_JUPITER_API_KEY"

# NEYNAR_API_KEY: Optional — live Farcaster / Neynar user scores on Passport™.
# Without it, /api/neynar/score returns a deterministic demo score.
# NEYNAR_API_KEY="MY_NEYNAR_API_KEY"

# TALENT_API_KEY: Optional — live Top 7 builders from Talent Protocol (talent.app).
# Without it, /api/talent/top-builders returns curated Top 7 with talent.app links.
# Create a key at https://docs.talent.app — header X-API-KEY.
# TALENT_API_KEY="MY_TALENT_API_KEY"

# FEEDBACK_ADMIN_TOKEN: Required to read GET /api/feedback (inbox dump).
# Keep secret — without it the list endpoint returns 401.
# FEEDBACK_ADMIN_TOKEN="change-me-long-random"

# Optional Solana RPC for wallet balance reads (Swap V2 execute does not need this).
# VITE_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Tradeable tokens (Solana / Jupiter) ---
# Only coins with TRADEABLE_<SYMBOL>=true can be quoted or swapped.
# If a key is omitted: SOL, USDC, USDT, JUP default ON; BONK, WIF, RAY default OFF.
TRADEABLE_SOL=true
TRADEABLE_USDC=true
TRADEABLE_USDT=true
TRADEABLE_JUP=true
TRADEABLE_BONK=false
TRADEABLE_WIF=false
TRADEABLE_RAY=false

# Avantis perps (Base) — Python sidecar uses avantis-trader-sdk for pairs + marks.
# Candles fall back to Binance public klines when the sidecar is offline.
# AVANTIS_SIDECAR_URL must be loopback only (SSRF guard).
# AVANTIS_BASE_RPC="https://mainnet.base.org"
# AVANTIS_SIDECAR_URL="http://127.0.0.1:8765"
# AVANTIS_SIDECAR_DISABLE="0"
